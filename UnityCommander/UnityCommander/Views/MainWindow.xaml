<Window
    x:Class="UnityCommander.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:at="clr-namespace:UnityCommander.AttachProperties"
    xmlns:controls="clr-namespace:UnityCommander.Controls.Window;assembly=UnityCommander.Controls"
    xmlns:conv="clr-namespace:UnityCommander.Converters"
    xmlns:core="clr-namespace:UnityCommander.Core;assembly=UnityCommander.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:inputBinding="clr-namespace:UnityCommander.Core.Behaviors;assembly=UnityCommander.Core"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:viewModels="clr-namespace:UnityCommander.ViewModels"
    xmlns:xcad="http://schemas.xceed.com/wpf/xaml/avalondock"
    x:Name="Window"
    Title="Unity Commander"
    Width="1350"
    Height="800"
    controls:WindowControl.ViewModel="{Binding ImportCustomWindow, Mode=OneWayToSource}"
    controls:WindowControl.WindowInstance="{Binding ElementName=Window, Mode=OneWay}"
    d:DataContext="{d:DesignInstance viewModels:MainWindowViewModel}"
    prism:ViewModelLocator.AutoWireViewModel="True"
    AllowsTransparency="True"
    Icon="{Binding Icon}"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    WindowStyle="None"
    mc:Ignorable="d">

    <Window.FontFamily>
        <DynamicResource ResourceKey="MaterialDesignFont" />
    </Window.FontFamily>
    <Window.Background>
        <DynamicResource ResourceKey="MaterialDesignPaper" />
    </Window.Background>
    <Window.Resources>
        <Style TargetType="MenuItem">
            <Style.BasedOn>
                <StaticResource ResourceKey="UcMenuItemStyle" />
            </Style.BasedOn>
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Height" Value="50" />
        </Style>
        <conv:BoolToBrushConverter x:Key="BoolToBrushConverter" />
    </Window.Resources>

    <Grid inputBinding:KeyboardBinding.IsEnable="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="69" MaxWidth="60" />
            <ColumnDefinition Width="Auto" MaxWidth="250" />
            <ColumnDefinition Width="0" />
            <ColumnDefinition Width="69*" MinWidth="800" />
            <ColumnDefinition Width="571*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="{Binding RibbonContainerSize}" />
            <RowDefinition Height="1*" />
            <RowDefinition at:Collapsible.IsCollapsed="{Binding IsBottomPanelVisible, RelativeSource={RelativeSource AncestorType=Window}}" />
            <RowDefinition Height="25" />
        </Grid.RowDefinitions>
        <!--
            Toolbar region.
        -->

        <ContentControl
            Grid.Row="0"
            Grid.Column="3"
            Grid.ColumnSpan="3"
            prism:RegionManager.RegionName="{x:Static core:RegionNames.ToolBarRegion}"
            Visibility="{Binding ToolBarVisibility}" />

        <!--
            Grid splitter.
        -->
        <GridSplitter
            Grid.Row="1"
            Grid.Column="2"
            Width="10"
            HorizontalAlignment="Center"
            DragIncrement="1"
            ResizeDirection="Columns"
            ShowsPreview="False" />
        <!--
            The content display region of ​​the left sidebar.
        -->
        <Grid
            Grid.Row="0"
            Grid.RowSpan="2"
            Grid.Column="1"
            Grid.ColumnSpan="2"
            Width="{Binding SidebarContentWidth, Mode=TwoWay}"
            Background="#F3F2F2">
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <ContentControl
                Grid.Row="0"
                Height="25"
                Margin="0,0,10,10"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Content="{Binding IconHideSidebar.Data}"
                Foreground="Gray">
                <ContentControl.Template>
                    <DynamicResource ResourceKey="CustomButtonTemplate" />
                </ContentControl.Template>
                <ContentControl.Style>
                    <DynamicResource ResourceKey="CustomButtonStyles" />
                </ContentControl.Style>
                <ContentControl.InputBindings>
                    <MouseBinding Command="{Binding HideSidebarCommand}" Gesture="LeftClick" />
                </ContentControl.InputBindings>
                <ContentControl.ToolTip>
                    <ToolTip Content="Collapse sidebar" />
                </ContentControl.ToolTip>
            </ContentControl>
            <Border Grid.Row="1" Background="#FFF3F2F2">
                <ContentControl Content="{Binding SidebarContent, Mode=TwoWay}" />
            </Border>
        </Grid>

        <!--
            Functional selection region on the left side panel.
        -->
        <ContentControl
            Grid.Row="0"
            Grid.RowSpan="3"
            Grid.Column="0"
            prism:RegionManager.RegionName="{x:Static core:RegionNames.LeftSideBarRegion}" />
        <!--
            File panel region.
        -->
        <Grid
            Grid.Row="1"
            Grid.Column="3"
            Grid.ColumnSpan="2"
            Background="#F3F2F2">
            <xcad:DockingManager x:Name="DockManager" x:FieldModifier="public" />
        </Grid>
        <Border
            Grid.Row="2"
            Grid.Column="3"
            Grid.ColumnSpan="3"
            Height="230">
            <ContentControl
                prism:RegionManager.RegionName="{x:Static core:RegionNames.BottomPanelRegion}"
                Background="#F3F2F2"
                Visibility="{Binding IsBottomPanelVisible, RelativeSource={RelativeSource AncestorType=Window}}" />
        </Border>
    </Grid>
    <!--<WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="46"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="15" />
    </WindowChrome.WindowChrome>-->
</Window>