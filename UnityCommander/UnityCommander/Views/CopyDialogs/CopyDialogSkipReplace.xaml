<UserControl
    x:Class="UnityCommander.Views.CopyDialogs.CopyDialogSkipReplace"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:UnityCommander.Views.CopyDialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <WrapPanel Width="300" Height="250">
            <Button
                Margin="5"
                Command="{Binding ReplaceCommand}"
                Content="Заменить" />
            <Button
                Margin="5"
                Command="{Binding ReplaceAllCommand}"
                Content="Заменить (Все)" />
            <Button
                Margin="5"
                Command="{Binding SkipCommand}"
                Content="Пропустить" />
            <Button
                Margin="5"
                Command="{Binding SkipAllCommand}"
                Content="Пропустить (Все)" />
        </WrapPanel>
    </Grid>
</UserControl>
