                                <TextBlock Grid.Row="0" Text="{Binding Source}" />
                                <TextBlock Grid.Row="1" Text="{Binding Destination}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </TabItem>
