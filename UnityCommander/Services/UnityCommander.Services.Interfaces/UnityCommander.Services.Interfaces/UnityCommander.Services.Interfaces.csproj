<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>netcoreapp3.1;net472</TargetFrameworks>
	<UseWPF>true</UseWPF>
	<LangVersion>9.0</LangVersion>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Config.Net" Version="4.15.0" />
    <PackageReference Include="MaterialDesign.Icons" Version="1.1.0" />
    <PackageReference Include="MaterialDesignThemes" Version="3.2.0" />
    <PackageReference Include="Prism.Core" Version="7.2.0.1422" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\UnityCommander.Common\UnityCommander.Common.csproj" />
  </ItemGroup>
	<Choose>
		<When Condition="'$(TargetFramework)'=='netcoreapp3.1'">
			<ItemGroup>
				<ProjectReference Include="..\..\..\UnityCommander.Plugin.NETCore\UnityCommander.Plugin.NETCore.csproj" />
				<ProjectReference Include="..\..\..\UnityCommander.Plugin.Core\UnityCommander.Plugin.Core.csproj" />
			</ItemGroup>
		</When>
		<When Condition="'$(TargetFramework)'=='net472'">
			<ItemGroup>
				<ProjectReference Include="..\..\..\UnityCommander.Plugin.NET48\UnityCommander.Plugin.NET48.csproj" />
			</ItemGroup>
		</When>
	</Choose>
</Project>
