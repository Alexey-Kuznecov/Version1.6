<UserControl
    x:Class="UnityCommander.Controls.Ribbon2.RibbonControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:UnityCommander.Controls.Ribbon2"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="clr-namespace:UnityCommander.Controls.Ribbon2.Models"
    xmlns:selectors="clr-namespace:UnityCommander.Controls.Ribbon2.Selectors"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <DataTemplate x:Key="ButtonToolTemplate" DataType="{x:Type model:RibbonToolModel}">
            <Button
                Command="{Binding Command, Mode=OneWay}"
                Content="{Binding DisplayName}"
                Style="{StaticResource RibbonButtonStyle}">
                <!--<Button.ContentTemplate />-->
            </Button>
        </DataTemplate>
        <selectors:RibbonToolTemplateSelector
            x:Key="ToolTemplateSelector"
            ButtonTemplate="{StaticResource ButtonToolTemplate}"
            ToggleTemplate="{StaticResource ToggleToolTemplate}" />
    </UserControl.Resources>
    <Grid>
        <ItemsControl ItemsSource="{Binding Model.Tabs}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <!--  Tab: render groups  -->
                    <StackPanel>
                        <TextBlock Text="{Binding Title}" />
                        <ItemsControl ItemsSource="{Binding Groups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!--  Group header + tools  -->
                                    <Border>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" />
                                            <ItemsControl ItemTemplateSelector="{StaticResource ToolTemplateSelector}" ItemsSource="{Binding Tools}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
