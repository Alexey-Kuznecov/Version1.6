<UserControl
    x:Class="UnityCommander.Modules.BottomPanel.Views.BottomPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="clr-namespace:UnityCommander.Core;assembly=UnityCommander.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:UnityCommander.Modules.BottomPanel.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    d:DesignHeight="250"
    d:DesignWidth="800"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>
        <!--  Левая вкладка: консоль / логи  -->

        <ContentControl Grid.Column="0" prism:RegionManager.RegionName="{x:Static core:RegionNames.ConsoleTabRegion}" />
       
        <!--  Правая вкладка: предпросмотр файлов  -->
        <Border
            Grid.Column="1"
            Margin="10,0,0,0"
            BorderBrush="{DynamicResource MaterialDesignDivider}"
            BorderThickness="1,0,0,0">
            <ContentControl prism:RegionManager.RegionName="{x:Static core:RegionNames.LogTabRegion}" />
            <!--<ContentControl prism:RegionManager.RegionName="{x:Static core:RegionNames.PreviewRegion}" />-->
        </Border>
    </Grid>
</UserControl>