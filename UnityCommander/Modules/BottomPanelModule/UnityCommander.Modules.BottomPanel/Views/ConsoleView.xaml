<UserControl
    x:Class="UnityCommander.Modules.BottomPanel.Views.ConsoleView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:UnityCommander.Modules.BottomPanel.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Margin="0" Background="#1E1E1E">

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Вывод  -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Lines}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock
                            FontFamily="Consolas"
                            Foreground="#dcdcdc"
                            Text="{Binding}"
                            TextWrapping="Wrap" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!--  Ввод  -->
        <DockPanel Grid.Row="1" Margin="0,4,0,0">
            <TextBlock
                VerticalAlignment="Center"
                FontFamily="Consolas"
                Foreground="#00ff90"
                Text="&gt; " />
            <TextBox
                Background="#2D2D30"
                BorderBrush="#3F3F46"
                FontFamily="Consolas"
                Foreground="White"
                KeyDown="TextBox_KeyDown"
                Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" />
        </DockPanel>

    </Grid>
</UserControl>
