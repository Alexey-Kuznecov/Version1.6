<UserControl
    x:Class="UnityCommander.Modules.BottomPanel.Views.ConsoleView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:at="clr-namespace:UnityCommander.Modules.BottomPanel.AttachProperties"
    xmlns:conv="clr-namespace:UnityCommander.Modules.BottomPanel.Converter"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:UnityCommander.Modules.BottomPanel.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="250"
    mc:Ignorable="d">

    <UserControl.Resources>
        <conv:CountToVisibilityConverter x:Key="CountToVisibility" />
    </UserControl.Resources>
    <Grid Margin="0" Background="#1E1E1E">

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Вывод  -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Lines}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock
                            Height="15"
                            Margin="5,2"
                            FontFamily="Consolas"
                            Foreground="#dcdcdc"
                            Text="{Binding}"
                            TextWrapping="Wrap" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!--  Ввод  -->
        <DockPanel Grid.Row="1" Margin="0,4,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!--  автокомплит  -->
                    <RowDefinition Height="Auto" />
                    <!--  ввод  -->
                </Grid.RowDefinitions>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="25" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="Consolas"
                        FontSize="16"
                        Foreground="#00ff90"
                        Text="&gt; " />
                    <TextBox
                        Grid.Column="1"
                        at:TextBoxCaretBinding.CaretIndex="{Binding CaretIndex, Mode=TwoWay}"
                        Background="#2D2D30"
                        BorderBrush="#3F3F46"
                        FontFamily="Consolas"
                        FontSize="16"
                        Foreground="White"
                        KeyDown="TextBox_KeyDown"
                        Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Up" Command="{Binding NavigateUpCommand}" />
                            <KeyBinding Key="Down" Command="{Binding NavigateDownCommand}" />
                            <KeyBinding Key="Enter" Command="{Binding SendCommand}" />
                            <KeyBinding Key="Tab" Command="{Binding AcceptCommand}" />
                            <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button
                        Grid.Column="2"
                        Command="{Binding CopyCommand}"
                        Content="Копировать" />
                </Grid>
                <!--  🔥 Оверлей автокомплита  -->
                <ListBox
                    Grid.Row="0"
                    MaxHeight="150"
                    Background="#222"
                    Foreground="White"
                    ItemsSource="{Binding Completions}"
                    SelectedIndex="{Binding SelectedIndex}"
                    Visibility="{Binding Completions.Count, Converter={StaticResource CountToVisibility}}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock
                                FontFamily="Consolas"
                                FontSize="14"
                                Text="{Binding DisplayText}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.Resources>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="FontFamily" Value="Consolas" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="Padding" Value="4" />
                            <Setter Property="Background" Value="Transparent" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#3A3D41" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Resources>
                </ListBox>
            </Grid>
        </DockPanel>
    </Grid>
</UserControl>
