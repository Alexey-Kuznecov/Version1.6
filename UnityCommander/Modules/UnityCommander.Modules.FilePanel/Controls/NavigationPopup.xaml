<UserControl
    x:Class="UnityCommander.Modules.FilePanel.Controls.NavigationPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:UnityCommander.Modules.FilePanel.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="400"
    d:DesignWidth="250"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Style="{DynamicResource NavigationPopupHeaderStyle}" />
        <Border Grid.Row="1" Style="{DynamicResource NavigationPopupContainerStyle}">
            <ListBox ItemsSource="{Binding DirectoryList, Mode=OneWay}" SelectedItem="{Binding SelectItem, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="local:PopupViewModel">
                        <WrapPanel>
                            <TextBlock Text="{Binding SelectedPath, Mode=OneWay}" />
                        </WrapPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</UserControl>