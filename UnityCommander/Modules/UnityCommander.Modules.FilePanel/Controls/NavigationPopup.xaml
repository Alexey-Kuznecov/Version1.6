<UserControl
    x:Class="UnityCommander.Modules.FilePanel.Controls.NavigationPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:UnityCommander.Modules.FilePanel.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="400"
    d:DesignWidth="250"
    mc:Ignorable="d">
    <!--<UserControl.DataContext>
        <local:NavigationPopupModel />
    </UserControl.DataContext>-->
    <Grid>
        <Border
            Width="400"
            Height="250"
            Background="LightSeaGreen">
            <ListBox ItemsSource="{Binding DirectoryList, Mode=TwoWay}" SelectedItem="{Binding SelectItem}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <WrapPanel>
                            <TextBlock Text="{Binding Path, Mode=TwoWay}" />
                        </WrapPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</UserControl>
