<UserControl
    x:Class="UnityCommander.Modules.FilePanel.Views.SplitPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:commands="clr-namespace:UnityCommander.Modules.FilePanel.Commands"
    xmlns:commands1="clr-namespace:UnityCommander.Common.Commands;assembly=UnityCommander.Common"
    xmlns:common="clr-namespace:UnityCommander.Common;assembly=UnityCommander.Common"
    xmlns:control="clr-namespace:UnityCommander.Modules.FilePanel.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dd="clr-namespace:UnityCommander.Core.DragDrop;assembly=UnityCommander.Core"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:viewModels="clr-namespace:UnityCommander.Modules.FilePanel.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:SplitPanelViewModel}"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style BasedOn="{StaticResource {x:Type GridViewColumnHeader}}" TargetType="{x:Type GridViewColumnHeader}">
            <Setter Property="Padding" Value="8,2,0,0" />
            <Setter Property="Height" Value="35" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" MinHeight="200" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="200" />
            <RowDefinition Height="50" />
            <!--<RowDefinition Height="50" />-->
        </Grid.RowDefinitions>

        <ContentControl Grid.Row="0" Template="{DynamicResource ContentDirectoryPanelTemplate}" />
        <!--
            Directory view
        -->
        <Grid Grid.Row="1">
            <!--
                This markup responds to display folder items.
                Template path: Resource\Generic.xml Name: DirectoryListViewTemplate
            -->
            <ContentControl Template="{Binding DirectoryPanelTemplate}" />
        </Grid>
        <GridSplitter
            Grid.Row="2"
            Height="5"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            ShowsPreview="False" />
        <!--
            All the logic that is responsible for working and displaying the file panel is behind the code,
            because there you need to add and update the column data.
            
            ItemContainerStyle="{StaticResource OverrideMaterialDesignGridViewItem}"
        -->
        <Grid Grid.Row="3">
            <ListView
                commands:GridViewSort.AutoSort="True"
                dd:DragDrop.DropHandler="{Binding Mode=Default}"
                dd:DragDrop.IsDragSource="True"
                IsSynchronizedWithCurrentItem="True"
                ItemsSource="{Binding FileList, Mode=OneWay}"
                SelectedItem="{Binding CurrentFile}"
                SelectionMode="Single"
                View="{Binding FilePanelContainer}">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel ContextMenu="{Binding ContextMenu}" />
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
            </ListView>
        </Grid>
        <ContentControl Grid.Row="4">
            <control:NavigationPanel
                Margin="10"
                DirectoryPath="{Binding CurrentDirectory, Mode=TwoWay}"
                NavigateCommand="{Binding UpdateCommand, Mode=OneWay}" />
        </ContentControl>
        <!--<Grid Grid.Row="4">
            <Button
                Width="50"
                commands1:MultiCommandParameter.IsInclude="True"
                Command="{Binding TestCommand}">
                <Button.Content>
                    <commands1:XArray Content="Start" Type="False">
                        <commands1:XParam Value="{Binding CurrentDirectory}" />
                        <commands1:XParam Value="{Binding CurrentDirectory}" />
                    </commands1:XArray>
                </Button.Content>
            </Button>
        </Grid>-->
        <!--<Grid Grid.Row="4">
            <Button Width="50" Command="{Binding TestCommand}">
                <Button.Content>
                    Test
                </Button.Content>
            </Button>
        </Grid>-->
    </Grid>
</UserControl>
