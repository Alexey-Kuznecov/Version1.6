<UserControl
    x:Class="UnityCommander.Modules.FilePanel.Views.ViewB"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:UnityCommander.Modules.FilePanel.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:module="clr-namespace:UnityCommander.Modules.FilePanel"
    xmlns:regions="http://prismlibrary.com/"
    xmlns:taber="clr-namespace:UnityCommander.Controls.Taber;assembly=UnityCommander.Controls"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="25" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <ContentControl Grid.Row="1" Template="{StaticResource ContentDirectoryPanelTemplate}" />
            <taber:TaberPanel Grid.Row="0" InitialElements="{Binding TabCollection, Mode=TwoWay}" />
            <ContentControl Grid.Row="2" regions:RegionManager.RegionName="{x:Static module:NestedRegionNames.RightPanelContentRegion}" />
        </Grid>
    </Grid>
</UserControl>
