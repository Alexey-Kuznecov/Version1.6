<UserControl
    x:Class="UnityCommander.Modules.FilePanel.Views.ViewA"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:UnityCommander.Controls.Taber;assembly=UnityCommander.Controls"
    xmlns:module="clr-namespace:UnityCommander.Modules.FilePanel"
    xmlns:prism="http://prismlibrary.com/"
    prism:ViewModelLocator.AutoWireViewModel="True">

    <Grid>
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="25" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <ContentControl Grid.Row="1" Template="{StaticResource ContentDirectoryPanelTemplate}" />
            <controls:TabPanel Grid.Row="0" Collection="{Binding TabCollection, Mode=TwoWay}" />
            <ContentControl Grid.Row="2" prism:RegionManager.RegionName="{x:Static module:NestedRegionNames.LeftPanelContentRegion}" />
        </Grid>
    </Grid>
</UserControl>
