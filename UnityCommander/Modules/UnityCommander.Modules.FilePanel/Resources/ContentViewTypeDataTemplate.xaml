<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:be="clr-namespace:UnityCommander.Modules.FilePanel.Behaviors"
    xmlns:commands="clr-namespace:UnityCommander.Modules.FilePanel.Commands"
    xmlns:control="clr-namespace:UnityCommander.Modules.FilePanel.Controls"
    xmlns:dd="clr-namespace:UnityCommander.Core.DragDrop;assembly=UnityCommander.Core"
    xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
    xmlns:layout="clr-namespace:UnityCommander.Modules.FilePanel.Layout"
    xmlns:models="clr-namespace:UnityCommander.Common.Commands;assembly=UnityCommander.Common"
    xmlns:selectors="clr-namespace:UnityCommander.Modules.FilePanel.Selectors"
    xmlns:state="clr-namespace:UnityCommander.Modules.FilePanel.States">

    <selectors:ContentTemplateSelector x:Key="ContentTemplateSelector" />

    <DataTemplate x:Key="DirectoryContentViewDataTemplate">
        <ListView
            be:GridViewColumnsBehavior.ColumnDefinitions="{Binding FolderViewColumns, Mode=Default}"
            be:MultiSelectionMouseBehavior.IsEnableSelection="False"
            dd:DragDrop.DropHandler="{Binding Mode=Default}"
            dd:DragDrop.IsDragSource="True"
            dd:DragDrop.IsDropTarget="True"
            DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
            IsSynchronizedWithCurrentItem="True"
            ItemsSource="{Binding DirectoryList, Mode=OneWay}"
            SelectedItem="{Binding SelectedDirectory}"
            SelectionMode="Multiple">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="PreviewMouseDoubleClick">
                    <i:InvokeCommandAction Command="{Binding NavigateDirectoryCommand, Mode=OneWay}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListBox}, Path=SelectedItem, Mode=OneWay}" />
                </i:EventTrigger>
                <i:EventTrigger EventName="MouseRightButtonUp">
                    <i:InvokeCommandAction Command="{Binding SelectCurrentDirectoryItem, Mode=OneWay}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListBox}, Path=SelectedItem, Mode=OneWay}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel ContextMenu="{Binding ContextMenu}" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
        </ListView>
    </DataTemplate>

    <DataTemplate x:Key="DashboardContentViewDataTemplate">
        <ListView
            be:GridViewColumnsBehavior.ColumnDefinitions="{Binding DriveViewColumns}"
            be:GridViewColumnsBehavior.PanelId="LeftPanel.Drive"
            commands:GridViewSort.AutoSort="True"
            IsSynchronizedWithCurrentItem="True"
            ItemsSource="{Binding DriveList, Mode=OneWay}">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="PreviewMouseDoubleClick">
                    <i:InvokeCommandAction
                        Command="{Binding GotoDiskCommand, Mode=OneWay}"
                        CommandName="NavigateDirCommand"
                        CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListBox}, Path=SelectedItem, Mode=OneWay}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </ListView>
    </DataTemplate>

    <DataTemplate x:Key="FileContentViewDataTemplate" DataType="{x:Type state:TabState}">
        <ListView
            be:GridViewColumnsBehavior.ColumnDefinitions="{Binding FileViewColumns, Mode=Default}"
            be:SelectionBehavior.EnableSelection="True"
            be:SelectionBehavior.Manager="{Binding SelectionManager}"
            be:SelectionBehavior.PanelId="{Binding Token}"
            commands:GridViewSort.AutoSort="True"
            dd:DragDrop.DropHandler="{Binding Mode=Default}"
            dd:DragDrop.IsDragSource="True"
            DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
            IsSynchronizedWithCurrentItem="True"
            ItemsSource="{Binding FileList, Mode=OneWay}"
            SelectedItem="{Binding CurrentFile}">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseRightButtonUp">
                    <i:InvokeCommandAction Command="{Binding SelectCurrentDirectoryItem, Mode=OneWay, PresentationTraceSources.TraceLevel=High}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListBox}, Path=SelectedItem, Mode=OneWay}" />
                </i:EventTrigger>
                <i:EventTrigger EventName="PreviewMouseRightButtonUp">
                    <i:InvokeCommandAction Command="{Binding ShowContextMenuCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListBox}, Path=SelectedItems, Mode=OneWay}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
            <!--<i:Interaction.Behaviors>
                  <be:MultiSelectionBehavior SelectedItems="{Binding SelectedItems, Mode=TwoWay}" />
              </i:Interaction.Behaviors>-->
            <ListView.ContextMenu>
                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}" ItemsSource="{Binding ContextMenuItems}">
                    <ContextMenu.ItemContainerStyle>
                        <Style BasedOn="{StaticResource MaterialDesignMenuItem}" TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding Title}" />
                            <Setter Property="Command" Value="{Binding Command}" />
                            <Setter Property="ItemsSource" Value="{Binding Children}" />
                        </Style>
                    </ContextMenu.ItemContainerStyle>
                </ContextMenu>
            </ListView.ContextMenu>
        </ListView>
    </DataTemplate>

    <DataTemplate x:Key="HeaderContentDataTemplate" DataType="{x:Type layout:ContentNode}">
        <Grid Style="{DynamicResource DirectoryPanelHeaderStyle}">
            <ItemsControl ItemsSource="{Binding Context.Commands}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:UICommand}">
                        <ContentControl
                            Grid.Column="0"
                            Height="25"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Content="{Binding Icon.Path.Data}"
                            Foreground="#E8E8EC"
                            Style="{DynamicResource CustomButtonStyles}"
                            Template="{DynamicResource CustomButtonTemplate}"
                            ToolTip="{Binding Description}">
                            <ContentControl.InputBindings>
                                <MouseBinding Command="{Binding Command}" Gesture="LeftClick" />
                            </ContentControl.InputBindings>
                        </ContentControl>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </DataTemplate>
</ResourceDictionary>