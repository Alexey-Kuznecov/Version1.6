<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">
  <PropertyGroup>
    <TargetFramework>netcoreapp3.1</TargetFramework>
    <UseWPF>true</UseWPF>
	  <LangVersion>9.0</LangVersion>
    <AssemblyName>UnityCommander.Modules.TabPanel</AssemblyName>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Prism.Wpf" Version="8.1.97" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\UnityCommander.Core\UnityCommander.Core.csproj" />
    <ProjectReference Include="..\UnityCommander.Modules.FilePanel\UnityCommander.Modules.FilePanel.csproj" />
    <ProjectReference Include="..\UnityCommander.Modules.Viewer\UnityCommander.Modules.Viewer.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Update="Views\RightPanelContentView.xaml.cs">
      <SubType>Code</SubType>
    </Compile>
  </ItemGroup>
  <ItemGroup>
    <Page Update="Views\LeftPanelContentView.xaml">
      <XamlRuntime>$(DefaultXamlRuntime)</XamlRuntime>
      <SubType>Designer</SubType>
    </Page>
    <Page Update="Views\RightPanelContentView.xaml">
      <XamlRuntime>$(DefaultXamlRuntime)</XamlRuntime>
      <SubType>Designer</SubType>
    </Page>
    <Page Update="Views\TabPanelView.xaml">
      <XamlRuntime>$(DefaultXamlRuntime)</XamlRuntime>
    </Page>
  </ItemGroup>
</Project>