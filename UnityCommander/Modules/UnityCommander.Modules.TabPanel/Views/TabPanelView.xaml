<UserControl
    x:Class="UnityCommander.Modules.TabPanel.Views.TabPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:UnityCommander.Controls.Taber;assembly=UnityCommander.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:module="clr-namespace:UnityCommander.Modules.TabPanel"
    xmlns:regions="http://prismlibrary.com/"
    d:DesignHeight="300"
    d:DesignWidth="300"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="300" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" MinWidth="300" />
        </Grid.ColumnDefinitions>
        <ContentControl Grid.Column="0" regions:RegionManager.RegionName="{x:Static module:NestedRegionNames.LeftFilePanelRegion}" />
        <GridSplitter
            Grid.Column="1"
            Width="5"
            HorizontalAlignment="Center"
            VerticalAlignment="Stretch"
            ShowsPreview="False" />
        <ContentControl Grid.Column="2" regions:RegionManager.RegionName="{x:Static module:NestedRegionNames.RightFilePanelRegion}" />
    </Grid>
</UserControl>
