<UserControl
    x:Class="UnityCommander.Modules.LeftSideBars.SidebarContent.ColumnsOptionControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:MaterialDesignThemes.Wpf.Converters;assembly=MaterialDesignThemes.Wpf"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:UnityCommander.Modules.LeftSideBars.SidebarContent"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:UnityCommander.Modules.LeftSideBars.ViewModels"
    xmlns:wpf="http://materialdesigninxaml.net/winfx/xaml/themes"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style BasedOn="{StaticResource UcToggleButton}" TargetType="ToggleButton">
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SecondaryAccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Width="{Binding SidebarContentWidth, FallbackValue=250}" Background="#FFF3F2F2">
        <Grid>
            <Grid.DataContext>
                <vm:ColumnOptionViewModel />
            </Grid.DataContext>
            <StackPanel>
                <TextBlock
                    Margin="20"
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="#3C3C3E"
                    Text="Managment Cloums Visibility" />
                <Grid Margin="20,15,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="100" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        FontSize="14"
                        FontWeight="Medium"
                        Foreground="#3C3C3E"
                        Text="Attributes" />
                    <ToggleButton
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        Background="#7C9BCC"
                        Style="{StaticResource UcToggleButton}" />
                </Grid>
                <Grid Margin="20,15,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="100" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        FontSize="14"
                        FontWeight="Medium"
                        Foreground="#3C3C3E"
                        Text="Creation Date" />
                    <ToggleButton
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        Background="#7C9BCC"
                        Style="{StaticResource UcToggleButton}" />
                </Grid>
                <Grid Margin="20,15,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="100" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        FontSize="14"
                        FontWeight="Medium"
                        Foreground="#3C3C3E"
                        Text="Last Access Date" />
                    <ToggleButton
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        Background="#7C9BCC"
                        Style="{StaticResource UcToggleButton}" />
                </Grid>
            </StackPanel>

            <!--<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <RadioButton Margin="0,10,0,0" Style="{StaticResource MaterialDesignActionRadioButton}">
                    <wpf:PackIcon Kind="Smiley" />
                </RadioButton>
                <RadioButton Margin="0,10,0,0" Style="{StaticResource MaterialDesignActionRadioButton}">
                    <wpf:PackIcon Kind="SmileyAngry" />
                </RadioButton>
                <RadioButton Margin="0,10,0,0" Style="{StaticResource MaterialDesignActionRadioButton}">
                    <wpf:PackIcon Kind="SmileyCry" />
                </RadioButton>
                <RadioButton Margin="0,10,0,0" Style="{StaticResource MaterialDesignActionRadioButton}">
                    <wpf:PackIcon Kind="SmileyExcited" />
                </RadioButton>
            </StackPanel>-->
        </Grid>
    </Grid>
</UserControl>
