<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesigh="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Style x:Key="DirectoryPanelHeaderStyle" TargetType="{x:Type Grid}">
        <Setter Property="Height" Value="25" />
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource GeneralHeaderColor}" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DirectoryPanelContainerStyle" TargetType="{x:Type Grid}">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource GeneralContainerColor}" />
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>