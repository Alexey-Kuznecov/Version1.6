<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DataTemplate x:Key="NormalItemTemplate">
        <Grid>
            <TextBlock
                Grid.Column="0"
                Height="auto"
                Text="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=ComboBoxItem}, Path=Content}">
            </TextBlock>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="SelectionBoxTemplate">
        <Grid>
            <TextBlock Grid.Column="0" Text="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=ComboBox}, Path=SelectedItem}" />
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="CombinedTemplate">
        <ContentPresenter
            x:Name="Presenter"
            Content="{Binding}"
            ContentTemplate="{StaticResource NormalItemTemplate}" />
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, ComboBoxItem, 1}}" Value="{x:Null}">
                <Setter TargetName="Presenter" Property="ContentTemplate" Value="{StaticResource SelectionBoxTemplate}" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>


