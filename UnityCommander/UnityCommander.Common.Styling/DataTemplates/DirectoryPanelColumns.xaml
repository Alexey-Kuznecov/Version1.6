<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converter="clr-namespace:UnityCommander.Common.Styling.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesigh="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <DataTemplate x:Key="ColumnNameDataTemplate" DataType="{x:Type DataGridCell}">
        <Grid d:DataContext="{d:DesignData}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="1"
                Width="250"
                Text="{Binding Name, Mode=TwoWay}" />
            <materialDesigh:PackIcon
                Grid.Column="0"
                Width="25"
                Foreground="#7C9BCC"
                Kind="File" />
        </Grid>
    </DataTemplate>
    <DataTemplate x:Key="ColumnExtensionDataTemplate" DataType="{x:Type DataGridCell}">
        <Grid d:DataContext="{d:DesignData}">
            <TextBlock Text="{Binding Extension}" />
        </Grid>
    </DataTemplate>
    <DataTemplate x:Key="ColumnCreationDateDataTemplate" DataType="{x:Type DataGridCell}">
        <Grid d:DataContext="{d:DesignData}">
            <TextBlock Foreground="Indigo" Text="{Binding CreationTime, Converter={converter:DateTimeConverter}}" />
        </Grid>
    </DataTemplate>
    <DataTemplate x:Key="ColumnLastAccessDateDataTemplate" DataType="{x:Type DataGridCell}">
        <Grid d:DataContext="{d:DesignData}">
            <TextBlock Foreground="Indigo" Text="{Binding LastAccessTime, Converter={converter:DateTimeConverter}}">
                <TextBlock.InputBindings>
                    <MouseBinding
                        Command="{Binding SortColumnCommand, Mode=Default}"
                        Gesture="LeftClick"
                        MouseAction="LeftClick" />
                </TextBlock.InputBindings>
            </TextBlock>
        </Grid>
    </DataTemplate>
</ResourceDictionary>